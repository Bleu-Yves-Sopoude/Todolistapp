<h1>All Tasks</h1>

<%= link_to "New task", new_task_path %>

<% if @tasks.empty? %>
  <p>No tasks available.</p>
<% else %>
  <ul>

  <%= select_tag :status, options_for_select(['pending', 'completed', 'in_progress'], params[:status]), include_blank: "All Statuses" %>
  <%= submit_tag 'Filter' %>
  <%= select_tag :sort_by, options_for_select([['Sort by Date Created', 'created_at'], ['Sort by Last Updated', 'updated_at']], params[:sort_by]), include_blank: "Select Sort Order" %>
  <%= submit_tag 'Sort' %>



    <% @tasks.each do |task| %>
      <li>
      <li><%= task.name %> - <%= task.status %></li>
        <%= link_to "Edit", edit_task_path(task) %> |
        <%= button_to "Delete", task_path(task), method: :delete, data: { confirm: "Are you sure?" } %>
      </li>
    <% end %>
  </ul>
<% end %>
